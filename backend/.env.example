APP_NAME=Logistics
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://YOUR_RENDER_BACKEND_URL

# React/Vite frontend origin — used by CORS (see config/cors.php).
# Local dev:  http://localhost:5173
# Production: https://YOUR_VERCEL_FRONTEND_URL
FRONTEND_URL=https://YOUR_VERCEL_FRONTEND_URL

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database ───────────────────────────────────────────────────────────────
# Production (Render Free Postgres):
#   Set DATABASE_URL to the Internal Database URL shown in the Render dashboard.
#   Format: postgres://USER:PASSWORD@HOST:5432/DBNAME
# Local dev (SQLite — no separate DB needed):
#   DB_CONNECTION=sqlite  (comment out DATABASE_URL below)
DB_CONNECTION=pgsql
DATABASE_URL=YOUR_RENDER_POSTGRES_DATABASE_URL

# ── Session / Queue / Cache ────────────────────────────────────────────────
# Use cookie/array drivers on Render Free (no Redis, no DB-backed queue).
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=array

# ── Mail (not used in MVP) ─────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="ops@logistix.kz"
MAIL_FROM_NAME="${APP_NAME}"
