# Laravel API base URL (include /api prefix).
# Set this to connect pages to the backend. Leave unset (or remove the line)
# to keep using the built-in mock data fallback — the app works either way.

# ── Local development ──────────────────────────────────────────────────────
# CORS note: php artisan serve binds to 127.0.0.1:8000. The frontend must
# run on http://localhost:5173 (not http://127.0.0.1:5173) because CORS is
# configured to allow http://localhost:5173.
#VITE_API_BASE_URL=http://127.0.0.1:8000/api

# ── Production (Render backend + Vercel frontend) ──────────────────────────
# Replace with the URL of your Render Web Service after deployment.
VITE_API_BASE_URL=https://YOUR_RENDER_BACKEND_URL/api
