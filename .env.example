# Laravel API base URL (include /api prefix).
# Set this to connect pages to the backend. Leave unset (or remove the line)
# to keep using the built-in mock data fallback — the app works either way.
#
# CORS note: php artisan serve binds to 127.0.0.1:8000 by default.
# The frontend must run on http://localhost:5173 (not http://127.0.0.1:5173)
# because CORS is configured to allow only http://localhost:5173.
VITE_API_BASE_URL=http://127.0.0.1:8000/api
